NODE_ENV=development

# PostgreSQL / Supabase
# Local no-Docker demo: set DEV_DB=pglite and run pnpm demo:setup/demo:dev.
DEV_DB=
DEV_DB_PATH=./dev-data/pglite
# Production/runtime Postgres URLs. Use csp_app for DATABASE_URL; never superuser/service_role for app runtime.
DATABASE_URL=postgres://csp_app:replace-with-strong-password@127.0.0.1:54322/postgres
# Production/service Postgres URL. Server-only service_role path.
SERVICE_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# PHI encryption. Use a high-entropy secret, at least 32 characters.
PHI_ENCRYPTION_KEY=replace-with-at-least-32-characters

# Auth
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
# Admin console network guard. Required in production; comma-separated IPs or IPv4 CIDR ranges.
ADMIN_IP_ALLOWLIST=127.0.0.1,::1

# Google Calendar. Required for supervisor OAuth calendar sync and booking.
# ops:smoke fails until these two values are configured.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
# Optional. Defaults to {origin}/api/me/google-calendar/callback.
GOOGLE_CALENDAR_REDIRECT_URI=

# Storage buckets expected by EPIC 0
CASE_FILES_BUCKET=case-files
QUALIFICATIONS_BUCKET=qualifications
COMPLETION_RECORDS_BUCKET=completion-records
# File storage adapter. Local keeps the no-Docker demo path; production uses supabase or s3.
STORAGE_MODE=local
LOCAL_STORAGE_DIR=./dev-data/storage
LOCAL_STORAGE_SECRET=replace-with-at-least-32-characters
SUPABASE_STORAGE_BUCKET=case-files
S3_BUCKET=case-files
S3_REGION=ap-northeast-2
S3_ENDPOINT=
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me

# Toss Payments. Use dev locally. In production, set TOSS_MODE=prod and real console keys.
TOSS_MODE=dev
TOSS_CLIENT_KEY=replace-me
TOSS_SECRET_KEY=replace-me
TOSS_WEBHOOK_SECRET=replace-with-at-least-32-characters
TOSS_API_BASE_URL=https://api.tosspayments.com

# Mailer. Dev logs payloads. Use resend for real outbound email.
MAILER_MODE=dev
MAIL_FROM=no-reply@example.com
RESEND_API_KEY=
RESEND_API_BASE_URL=https://api.resend.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

SENTRY_DSN=

# Figma design token sync. Leave empty to skip gracefully.
FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=
