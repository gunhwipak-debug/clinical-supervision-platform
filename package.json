{
  "name": "clinical-supervision-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev:web": "pnpm --filter @csp/web dev",
    "dev:admin": "pnpm --filter @csp/admin dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck && tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "drizzle:check": "pnpm --filter @csp/db drizzle:check",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm drizzle:check",
    "demo:setup": "tsx scripts/demo-setup.ts",
    "demo:dev": "tsx scripts/demo-dev.ts",
    "demo:run": "tsx scripts/demo-run.ts",
    "journey:audit": "tsx scripts/user-journey-audit.ts",
    "journey:matrix": "tsx scripts/role-matrix-audit.ts",
    "ops:smoke": "tsx scripts/ops-smoke.ts",
    "ops:db-smoke": "tsx scripts/real-db-smoke.ts",
    "files:purge-expired": "tsx scripts/purge-expired-case-files.ts",
    "bookings:expire-holds": "tsx scripts/expire-stale-booking-holds.ts",
    "bookings:retry-calendar-cancellations": "tsx scripts/retry-calendar-cancellations.ts",
    "notifications:retention-warnings": "tsx scripts/send-retention-warnings.ts",
    "notifications:session-reminders": "tsx scripts/send-session-reminders.ts",
    "figma:push": "tsx scripts/figma-push.ts",
    "figma:pull": "tsx scripts/figma-pull.ts",
    "figma:init": "tsx scripts/figma-init.ts",
    "figma:sync": "pnpm figma:push && pnpm figma:pull",
    "e2e": "playwright test",
    "verify:stitch-coverage": "tsx scripts/verify-stitch-coverage.ts",
    "design:handoff": "tsx scripts/design-handoff.ts && prettier demo-evidence/DESIGN-HANDOFF.md demo-evidence/DESIGN-HANDOFF.json --write",
    "design:stitch-prompts": "pnpm design:handoff && tsx scripts/design-stitch-prompts.ts && prettier demo-evidence/STITCH-PROMPTS.md demo-evidence/STITCH-PROMPTS.json --write"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@eslint/js": "^9.39.1",
    "@netlify/plugin-nextjs": "^5.15.11",
    "@next/eslint-plugin-next": "15.5.18",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.13"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/material-symbols-outlined": "^5.2.45",
    "@fontsource/pretendard": "^5.2.5",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@netlify/database": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.16.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "react-hook-form": "^7.76.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  }
}
